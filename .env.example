# Copy to .env and fill in. Never commit your real .env.

# The subdomain pointing at this server. Caddy gets a Let's Encrypt cert for it.
CHECKIN_DOMAIN=your-domain.example.com

# Friendly name shown in the app.
CHECKIN_SERVER_NAME=Check-In

# Default phone country calling code applied to bare national numbers so contacts saved
# as "+1 (415) 555-0148" match a friend who types "(415) 555-0148". Default "1" (US/
# Canada). Set to your code (e.g. "44" UK, "61" AU). Numbers entered with a leading +
# are always taken as-is.
# CHECKIN_DEFAULT_COUNTRY_CODE=1

# Database credentials (used by both Postgres and the server connection string).
POSTGRES_USER=checkin
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=checkin

# Optional: pin a specific released image instead of :latest
# CHECKIN_IMAGE=ghcr.io/nc1107/check-in:v1.0.0

# Optional: enable the /debug maintenance web view (stats, member phone numbers, and a
# destructive "reset to first-login" DB wipe). Leave blank to disable entirely. When set,
# visit https://<domain>/debug?token=<this value>. Generate with: openssl rand -base64 32
# CHECKIN_DEBUG_TOKEN=
