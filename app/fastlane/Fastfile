# Fastlane lanes for releasing the Check-In app to the stores from CI.
# These run from the `app/` directory.

default_platform(:android)

platform :android do
  desc "Build and upload the Android App Bundle to the Play Store internal track"
  lane :internal do
    version_code = ENV['VERSION_CODE'] || ENV['GITHUB_RUN_NUMBER'] || '1'
    sh("flutter", "build", "appbundle", "--release",
       "--build-name=#{ENV['VERSION']}",
       "--build-number=#{version_code}")
    upload_to_play_store(
      package_name: "top.npcserver.checkin",
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
