# Fastlane lanes for releasing the Check-In app to the stores from CI.
# These are scaffolds — they assume the signing secrets documented in docs/DEPLOYMENT.md
# are present in the CI environment. They run from the `app/` directory.

default_platform(:android)

platform :android do
  desc "Build and upload the Android App Bundle to the Play Store internal track"
  lane :internal do
    # The .aab is produced by `flutter build appbundle` in CI before this lane runs.
    sh("flutter", "build", "appbundle", "--release", "--build-name=#{ENV['VERSION']}")
    upload_to_play_store(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_SERVICE_ACCOUNT_JSON"],
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

platform :ios do
  desc "Build and upload the iOS app to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"]
    )

    # `match` fetches the signing certificates/profiles from your private match repo.
    match(type: "appstore", readonly: true, git_url: ENV["MATCH_GIT_URL"])

    sh("flutter", "build", "ios", "--release", "--no-codesign", "--build-name=#{ENV['VERSION']}")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store"
    )
    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end
end
