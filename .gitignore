# Secrets / local config
.env
*.env.local

# Server
server/data/
server/server
server/check-in-server*
*.out

# Credentials — defense-in-depth; these must never be committed. (The committed
# google-services.json / GoogleService-Info.plist are client config, not secrets,
# and don't match these patterns.)
*service-account*.json
fcm-*.json
*.p8
AuthKey_*.p8

# Flutter / Dart
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/.idea/
app/ios/Pods/
app/ios/.symlinks/
app/android/.gradle/
app/android/local.properties
app/android/key.properties
app/**/*.g.dart
app/**/*.freezed.dart
*.keystore
*.jks
*.p12
*.mobileprovision

# OS / editor
.DS_Store
*.swp
.vscode/

# Tooling / session data
.claude/
.playwright-mcp/
downloads/
